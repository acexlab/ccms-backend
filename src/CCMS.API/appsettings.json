{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=ccms;user=root;password=YOUR_LOCAL_DB_PASSWORD"
  },
  "JwtSettings": {
    "Secret": "YOUR_SUPER_SECRET_JWT_KEY_THAT_IS_LONG_ENOUGH",
    "Issuer": "CCMS.API",
    "Audience": "CCMS.Client"
  },
  "BatchSettings": {
    "IntervalMinutes": 1
  },
  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true;",
    "ContainerName": "ccms-uploads"
  },
  "AllowedHosts": "*"
}