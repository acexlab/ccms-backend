{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ccms-log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=ccms;user=root;password=root"
  },
  "JwtSettings": {
    "Secret": "YOUR_SUPER_SECRET_JWT_KEY_THAT_IS_LONG_ENOUGH",
    "Issuer": "CCMS.API",
    "Audience": "CCMS.Client"
  },
  "BatchSettings": {
    "IntervalMinutes": 1
  },
  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true;",
    "ContainerName": "ccms-uploads"
  },
  "AllowedHosts": "*"
}