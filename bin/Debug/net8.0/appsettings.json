{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ccms-log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CCMS;User Id=sa;Password=YourSecurePassword123!;TrustServerCertificate=True;",
    "AzureBlobConnection": "UseDevelopmentStorage=true"
  },
  "JwtSettings": {
    "Secret": "SuperSecretJWTKey12345678901234567890",
    "Issuer": "CCMS.API",
    "Audience": "CCMS.Client",
    "ExpiryMinutes": "480"
  },
  "FileStorage": {
    "StorageMode": "Local",
    "LocalBasePath": "uploads",
    "BaseUrl": "http://localhost:5000/uploads",
    "AzureBlobConnectionString": "UseDevelopmentStorage=true",
    "AzureBlobContainerName": "ccms-documents"
  },
  "BatchJob": {
    "IntervalMinutes": "15"
  },
  "Swagger": {
    "Enabled": "true"
  },
  "AllowedHosts": "*"
}
