/*
 * File: appsettings.Production.json
 * Description: Production environment configurations.
 * To Implement: All sensitive values must be injected via Kubernetes secrets or config maps.
 */
{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "SET_VIA_K8S_SECRET",
    "AzureBlobConnection": "SET_VIA_K8S_SECRET"
  },
  "JwtSettings": {
    "Secret": "SET_VIA_K8S_SECRET",
    "Issuer": "CCMS.API",
    "Audience": "CCMS.Client",
    "ExpiryMinutes": "480"
  },
  "FileStorage": {
    "StorageMode": "AzureBlob",
    "AzureBlobConnectionString": "SET_VIA_K8S_SECRET",
    "AzureBlobContainerName": "ccms-documents"
  },
  "BatchJob": {
    "IntervalMinutes": "15"
  },
  "Swagger": {
    "Enabled": "false"
  },
  "AllowedHosts": "*"
}
