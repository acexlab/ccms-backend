    {
      "name": "Court Portal",
      "item": [
        {
          "name": "Create Freeze Case",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"last_case_number\", jsonData.caseNumber);",
                  "pm.test(\"Case number is generated\", function () {",
                  "    pm.expect(jsonData.caseNumber).to.not.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "ComplainantName",
                  "value": "State Tax Dept",
                  "type": "text"
                },
                {
                  "key": "ComplainantId",
                  "value": "TAX12345",
                  "type": "text"
                },
                {
                  "key": "DefendantName",
                  "value": "Rajesh Kumar",
                  "type": "text"
                },
                {
                  "key": "DefendantId",
                  "value": "123456789012",
                  "type": "text"
                },
                {
                  "key": "DefendantAccountNumber",
                  "value": "111122223333",
                  "type": "text"
                },
                {
                  "key": "DefendantBankName",
                  "value": "SBI",
                  "type": "text"
                },
                {
                  "key": "OrderType",
                  "value": "FreezeAccount",
                  "type": "text"
                },
                {
                  "key": "FreezeAmount",
                  "value": "10000",
                  "type": "text"
                },
                {
                  "key": "courtOrderFile",
                  "description": "Needs to be PDF",
                  "type": "file",
                  "src": "wwwroot/test-files/small-order.pdf"
                },
                {
                  "key": "aadhaarFile",
                  "description": "Aadhaar Copy",
                  "type": "file",
                  "src": "wwwroot/test-files/aadhaar.jpg"
                },
                {
                  "key": "panFile",
                  "description": "PAN Copy",
                  "type": "file",
                  "src": "wwwroot/test-files/pan.png"
                }
              ]
            },
